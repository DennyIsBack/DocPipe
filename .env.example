# Copie para .env e troque os valores. O .env real é ignorado pelo git.
# cp .env.example .env

# --- PostgreSQL ---
POSTGRES_DB=docpipe
POSTGRES_USER=docpipe
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=docpipe
RABBITMQ_DEFAULT_PASS=changeme
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# --- Redis ---
REDIS_PORT=6379

# --- MinIO (object storage compatível com S3) ---
MINIO_ROOT_USER=docpipe
MINIO_ROOT_PASSWORD=changeme123
MINIO_BUCKET=documents
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- API ---
API_PORT=8080
# Chave aceita no header X-API-Key (Fase 0: chave única em config; Fase 1: hash no banco)
DOCPIPE_API_KEY=dev-local-key
# Tamanho máximo de upload em bytes (20 MB)
DOCPIPE_MAX_UPLOAD_BYTES=20971520
